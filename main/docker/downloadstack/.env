# General settings
TZ=Europe/Amsterdam
PUID=1000
PGID=1000

# QBitTorrent settings
# QBITTORRENT_MODS=ghcr.io/techclusterhq/qbt-portchecker:main
# GLUETUN_PORTCHECKER_API_KEY=<APIKEY>

# MeTube settings
METUBE_DOWNLOAD_DIRECTORY=/mnt/nas/path/to/your/download/directory

# Soulseek settings
SOULSEEK_USERNAME=username
SOULSEEK_PASSWORD=password

# Slskd settings
SLSKD_API_KEY=apikey
SLSKD_DOWNLOAD_DIRECTORY=/mnt/nas/path/to/slskd/downloads
SLSKD_INCOMPLETE_DIRECTORY=/mnt/nas/path/to/slskd/incomplete
# SLSKD_SHARED_DIRECTORY=/mnt/nas/path/to/your/music/folder
# SLSKD_VPN_PORT_FORWARDING=true
VPN_API_KEY=apikey
