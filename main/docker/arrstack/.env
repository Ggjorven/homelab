# General settings
TZ=Europe/Amsterdam
PUID=1000
PGID=1000

# Soularr settings
SOULARR_DOWNLOAD_INTERVAL=300 # Seconds
SLSKD_API_KEY=apikey
SLSKD_DOWNLOAD_DIRECTORY=/mnt/nas/path/to/slskd/downloads

# AutoSubSync
AUTOSUBSYNC_INPUT_DIRECTORY=./autosubsync/input
AUTOSUBSYNC_OUTPUT_DIRECTORY=./autosubsync/output
AUTOSUBSYNC_DESKTOP_DIRECTORY=./autosubsync/desktop
